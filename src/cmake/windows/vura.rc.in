IDI_ICON1 ICON DISCARDABLE "cmake/windows/vura.ico"

1 VERSIONINFO
FILEVERSION ${VURA_VERSION_MAJOR},${VURA_VERSION_MINOR},${VURA_VERSION_PATCH},0
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904B0"
    BEGIN
      VALUE "CompanyName", "Hale Software"
      VALUE "FileDescription", "Vura"
      VALUE "FileVersion", "${VURA_VERSION_CANONICAL}"
      VALUE "InternalName", "vura"
      VALUE "OriginalFilename", "vura"
      VALUE "ProductName", "Vura"
      VALUE "ProductVersion", "${VURA_VERSION_CANONICAL}"
      VALUE "Comments", "Free and open source video player and editor designed for customization"
      VALUE "LegalCopyright", "${VURA_LEGAL_COPYRIGHT}"
    END
  END

  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x0409, 0x04B0
  END
END